# ─── 观澜 (Guanlan) 后端环境变量模板 ──────────────────────────────────
#
# 使用方法:
#   1. 复制此文件: cp .env.example .env
#   2. 根据本地环境修改 .env 中的值
#   3. .env 文件不会被提交到版本控制
#
# ───────────────────────────────────────────────────────────────────────

# ── 数据库 ────────────────────────────────────────────────────────────
# 数据库 URL (支持 SQLite 和 PostgreSQL)
# SQLite (开发环境):
DATABASE_URL=sqlite+aiosqlite:///./guanlan.db
# PostgreSQL (生产环境):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/guanlan

# ── JWT 认证 ──────────────────────────────────────────────────────────
# JWT 签名密钥 (生产环境务必修改为随机字符串)
JWT_SECRET=guanlan-dev-secret
# JWT 算法 (建议保持不变)
JWT_ALGORITHM=HS256
# Token 过期时间 (分钟)
JWT_EXPIRE_MINUTES=60

# ── 服务运行时 ────────────────────────────────────────────────────────
# API 前缀
API_PREFIX=/api/v1
# 服务监听配置
HOST=0.0.0.0
PORT=8000
# CORS 允许的源 (逗号分隔)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── 行情数据源 ────────────────────────────────────────────────────────
# 搜索缓存 TTL (秒)，默认 300
SEARCH_CACHE_TTL=300

# ── 日志 ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── 开发模式 ──────────────────────────────────────────────────────────
# 开启后启用 /docs 和 /redoc 文档
DEBUG=true
